pkg install proot-distro -y
proot-distro install debian
proot-distro login debian
apt update && apt install -y curl
curl -fsSL https://nodesource.com | bash -
apt install -y nodejs git build-essential
apt update && apt install -y git nodejs npm
npm install
npm link
npm install -g opencode-ai

option 2

pkg install proot-distro -y
proot-distro install alpine
proot-distro login alpine
apk update
apk add --no-cache nodejs npm git build-base
apk update && apk add --no-cache git
nodejs npm build-base
npm install -g opencode-ai

or

For Alpine Linux, the equivalent of:

apt update && apt install -y git nodejs npm

is:

apk update && apk add --no-cache git nodejs npm

If you also need compiler tools (equivalent to Debian's build-essential):

apk update && apk add --no-cache git nodejs npm build-base

To check that everything installed correctly:

node -v
npm -v
git --version

If you're trying to install OpenCode on Alpine, you can then run:

npm install -g opencode-ai

or

npx opencode-ai

depending on how you want to use it.
